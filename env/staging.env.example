# Staging mirrors production; only APP_ENV, APP_URL, and DB_DATABASE differ.
# Public staging must NOT use auth bypass - set ADMIN_API_TOKEN, HORIZON_* and ADMIN_* auth.

APP_ENV=staging
APP_DEBUG=0
APP_URL=https://staging.moviemind.dev
# Railway: use generated URL or custom domain, e.g. https://your-app.up.railway.app
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=moviemind_staging
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# Logging: same stack as production (daily files + stderr)
LOG_CHANNEL=production
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# Horizon Configuration
# IMPORTANT: On public staging, HORIZON_AUTH_BYPASS_ENVS must be empty (same as production).
HORIZON_AUTH_BYPASS_ENVS=
# REQUIRED - set to admin email addresses (username in Basic Auth = email)
HORIZON_ALLOWED_EMAILS=admin@example.com,ops@example.com
# REQUIRED - use strong password (min 32 characters recommended)
HORIZON_BASIC_AUTH_PASSWORD=super-secure-password-here
HORIZON_TIMEOUT=120
HORIZON_TRIES=3

OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=gpt-4o-mini
OPENAI_BACKOFF_ENABLED=true
OPENAI_BACKOFF_INTERVALS=10,30,120

# TMDb API Configuration
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=${TMDB_API_KEY}

# Admin API Configuration
# IMPORTANT: On public staging, ADMIN_AUTH_BYPASS_ENVS must be empty (same as production).
ADMIN_AUTH_BYPASS_ENVS=
# REQUIRED for /api/v1/admin/* - set strong random token (e.g. 64 chars), use header X-Admin-Token or Bearer
ADMIN_API_TOKEN=
# REQUIRED - set to admin email addresses (for Basic Auth where used)
ADMIN_ALLOWED_EMAILS=admin@example.com,ops@example.com
# REQUIRED - use strong password (min 32 characters recommended)
ADMIN_BASIC_AUTH_PASSWORD=super-secure-password-here

# Feature Flags Configuration
# NOTE: Same priority as production (env _FORCE > database > _DEFAULT)

# --- CORE AI ---
FEATURE_AI_DESCRIPTION_GENERATION=${FEATURE_AI_DESCRIPTION_GENERATION}
FEATURE_AI_DESCRIPTION_GENERATION_FORCE=
FEATURE_AI_BIO_GENERATION=${FEATURE_AI_BIO_GENERATION}
FEATURE_AI_BIO_GENERATION_FORCE=

# --- QUALITY ---
FEATURE_HALLUCINATION_GUARD=true
FEATURE_TMDB_VERIFICATION=true

# --- INSTANCE SCALING ---
# FEATURE_VIDEO_PROCESSING_FORCE=false

INSTANCE_ID=${INSTANCE_ID}
