APP_ENV=production
APP_DEBUG=0
APP_URL=https://api.moviemind.com
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=moviemind_prod
DB_USERNAME=${DB_USERNAME}
DB_PASSWORD=${DB_PASSWORD}

CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# Logging: production stack = daily files + stderr (for Docker/log collection)
LOG_CHANNEL=production
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# Horizon Configuration
# IMPORTANT: In production, HORIZON_AUTH_BYPASS_ENVS must be empty!
# Environments that bypass Horizon authorization (comma-separated)
# Production should NEVER bypass authorization
HORIZON_AUTH_BYPASS_ENVS=
# Authorized email addresses for Horizon dashboard access (comma-separated)
# REQUIRED in production - set to admin email addresses
HORIZON_ALLOWED_EMAILS=admin@example.com,ops@example.com
# Basic Auth password for Horizon dashboard
# REQUIRED in production - use strong password (min 32 characters recommended)
# This password is used as HTTP Basic Auth password (username = email from HORIZON_ALLOWED_EMAILS)
HORIZON_BASIC_AUTH_PASSWORD=super-secure-password-here
HORIZON_TIMEOUT=120
HORIZON_TRIES=3

OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=gpt-4o-mini
OPENAI_BACKOFF_ENABLED=true
OPENAI_BACKOFF_INTERVALS=10,30,120

# TMDb API Configuration
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=${TMDB_API_KEY}

# Admin API Basic Auth Configuration
# IMPORTANT: In production, ADMIN_AUTH_BYPASS_ENVS must be empty!
# Environments that bypass Admin API authorization (comma-separated)
# Production should NEVER bypass authorization
ADMIN_AUTH_BYPASS_ENVS=
# Authorized email addresses for Admin API access (comma-separated)
# REQUIRED in production - set to admin email addresses
ADMIN_ALLOWED_EMAILS=admin@example.com,ops@example.com
# Basic Auth password for Admin API
# REQUIRED in production - use strong password (min 32 characters recommended)
# This password is used as HTTP Basic Auth password (username = email from ADMIN_ALLOWED_EMAILS)
ADMIN_BASIC_AUTH_PASSWORD=super-secure-password-here

# Feature Flags Configuration
# NOTE: Features are resolved by priority:
# 1. _FORCE (Environment Variable) - Overrides UI and Defaults (UI Locked)
# 2. Database Value (UI) - Settable via /admin/features
# 3. _DEFAULT (Environment Variable) - Initial state if DB entry missing

# --- CORE AI ---
FEATURE_AI_DESCRIPTION_GENERATION=${FEATURE_AI_DESCRIPTION_GENERATION}
FEATURE_AI_DESCRIPTION_GENERATION_FORCE=
FEATURE_AI_BIO_GENERATION=${FEATURE_AI_BIO_GENERATION}
FEATURE_AI_BIO_GENERATION_FORCE=

# --- QUALITY ---
# Production should enforce validations
FEATURE_HALLUCINATION_GUARD=true
FEATURE_TMDB_VERIFICATION=true

# --- INSTANCE SCALING ---
# Use _FORCE to specialize instances (e.g. Worker vs API)
# FEATURE_VIDEO_PROCESSING_FORCE=false

INSTANCE_ID=${INSTANCE_ID}
