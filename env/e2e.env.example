# E2E tests: overrides so Playwright (baseURL http://127.0.0.1:8000) and Laravel use the same host.
# Before npm run test:e2e start the stack with: docker compose -f compose.yml -f compose.e2e.yml up -d --force-recreate
# Copy to api/.env.e2e and use with compose.e2e.yml, or rely on the override (APP_URL set in compose).
# Optional: add other E2E-only vars here (e.g. SESSION_DRIVER, logging).

APP_URL=http://127.0.0.1:8000
