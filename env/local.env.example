APP_ENV=local
APP_DEBUG=1
# E2E: use compose.e2e.yml override so APP_URL=127.0.0.1:8000; do not change this for normal dev.
APP_URL=http://localhost:8000
APP_KEY=

DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=moviemind
DB_USERNAME=moviemind
DB_PASSWORD=moviemind

CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=redis
REDIS_PORT=6379

# Horizon Configuration
# Environments that bypass Horizon authorization (comma-separated)
# Local and staging can bypass for easier development
HORIZON_AUTH_BYPASS_ENVS=local,staging
# Authorized email addresses for Horizon dashboard access (comma-separated)
# Leave empty for local development (bypass enabled)
HORIZON_ALLOWED_EMAILS=
# Basic Auth password for Horizon dashboard (only used in production)
# Leave empty for local development (bypass enabled)
HORIZON_BASIC_AUTH_PASSWORD=
HORIZON_TIMEOUT=120
HORIZON_TRIES=3

OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_BACKOFF_ENABLED=true
OPENAI_BACKOFF_INTERVALS=20,60,180

# TMDb API Configuration
# Get your API key from: https://www.themoviedb.org/settings/api
# Note: TMDb requires commercial license for production use. See docs/LEGAL_TMDB_LICENSE.md
TMDB_API_KEY=your-tmdb-api-key-here

# TVmaze API Configuration
# TVmaze API is free and does not require an API key (public API)
# Note: TVmaze allows commercial use under CC BY-SA license. Attribution required.
# See docs/LEGAL_TVMAZE_LICENSE.md for licensing details
# TVMAZE_API_KEY= (not required - TVmaze is a public API)

# AI Service Configuration
# Options: 'mock' (for local development/testing) or 'real' (for production with Events + Jobs)
AI_SERVICE=mock

# Admin API Basic Auth Configuration
# Environments that bypass Admin API authorization (comma-separated)
# Local and staging can bypass for easier development
ADMIN_AUTH_BYPASS_ENVS=local,staging
# Authorized email addresses for Admin API access (comma-separated)
# Leave empty for local development (bypass enabled)
ADMIN_ALLOWED_EMAILS=
# Basic Auth password for Admin API (only used in production)
# Leave empty for local development (bypass enabled)
ADMIN_BASIC_AUTH_PASSWORD=

# Notification Webhooks Configuration
# Secret key for verifying incoming notification webhooks (HMAC-SHA256)
NOTIFICATION_WEBHOOK_SECRET=your-notification-webhook-secret
# Enable/disable signature verification for incoming notification webhooks
WEBHOOK_VERIFY_NOTIFICATION_SIGNATURE=true

# Outgoing Webhooks Configuration
# Webhook URLs for outgoing notifications (comma-separated or separate variables)
WEBHOOK_URL_MOVIE_GENERATION_COMPLETED=https://example.com/webhook
WEBHOOK_URL_PERSON_GENERATION_COMPLETED=https://example.com/webhook
WEBHOOK_URL_GENERATION_COMPLETED=https://example.com/webhook
WEBHOOK_URL_GENERATION_FAILED=https://example.com/webhook
# Secret key for signing outgoing webhooks (HMAC-SHA256)
OUTGOING_WEBHOOK_SECRET=your-outgoing-webhook-secret
# Maximum retry attempts for outgoing webhooks
WEBHOOK_OUTGOING_MAX_ATTEMPTS=3
# Retry delays in minutes (exponential backoff)
WEBHOOK_RETRY_DELAY_1=1
WEBHOOK_RETRY_DELAY_2=5
WEBHOOK_RETRY_DELAY_3=15

# Feature Flags Configuration
# NOTE: Features are resolved by priority:
# 1. _FORCE (Environment Variable) - Overrides UI and Defaults (UI Locked)
# 2. Database Value (UI) - Settable via /admin/features
# 3. _DEFAULT (Environment Variable) - Initial state if DB entry missing

# --- CORE AI ---
FEATURE_AI_DESCRIPTION_GENERATION=true
FEATURE_AI_DESCRIPTION_GENERATION_FORCE=
FEATURE_AI_BIO_GENERATION=true
FEATURE_AI_BIO_GENERATION_FORCE=

# --- QUALITY ---
FEATURE_AI_QUALITY_SCORING=false
FEATURE_HALLUCINATION_GUARD=true

# --- INSTANCE SCALING (SPLIT MONOLITH) ---
# Use _FORCE variables to lock down specific instances (e.g., disable workers on API nodes)
# FEATURE_AI_DESCRIPTION_GENERATION_FORCE=false

# Unique identifier for this instance (required for logging/debugging)
INSTANCE_ID=api-1
# List of all instance URLs for monitoring (optional)
# Format: INSTANCE_URLS=instance-id:http://host:port,instance-id2:http://host2:port2
# Example: INSTANCE_URLS=api-1:http://api-1:8000,api-2:http://api-2:8000,api-3:http://api-3:8000
INSTANCE_URLS=
